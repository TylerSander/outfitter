{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Outfitter",
  "version": "0.7.0",
  "identifier": "app.outfitter.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Outfitter",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdENjU1RDdBQjZCOEUwMjEKUldRaDRMaTJlbDFsZmJ4RFhVakkyZ2UxelcrOTdPejBFVXErQXVkcXQyS091K1loamJCUUVrRkkK",
      "endpoints": [
        "https://github.com/TylerSander/outfitter/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
